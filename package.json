{
  "name": "cloudflare-inquiry-web-form",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:pages": "wrangler pages dev dist --port 8788",
    "build": "tsc -b && vite build",
    "deploy:pages": "wrangler pages deploy dist",
    "lint": "eslint --ext .js,.jsx,.ts,.tsx .",
    "lint:fix": "eslint --fix --ext .js,.jsx,.ts,.tsx .",
    "format": "prettier --write '**/*.{js,jsx,ts,tsx,json,css,scss,md,html,htm}'",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,css,scss,md,html,htm}\"",
    "typecheck": "tsc -b",
    "preview": "vite preview",
    "test": "vitest run --coverage",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "hono": "^4.12.14",
    "mimetext": "^3.0.28",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.8",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^3.2.4",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^10.2.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^29.0.2",
    "prettier": "^3.8.2",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^7.3.2",
    "vitest": "^3.2.4",
    "wrangler": "^4.81.1"
  },
  "pnpm": {
    "overrides": {
      "hono@<4.11.4": ">=4.11.4",
      "undici@>=7.0.0 <7.18.2": ">=7.18.2",
      "hono@<4.11.10": ">=4.11.10",
      "minimatch@<3.1.3": "3.1.5",
      "minimatch@>=9.0.0 <9.0.6": "9.0.9",
      "rollup@>=4.0.0 <4.59.0": ">=4.59.0",
      "minimatch@>=9.0.0 <9.0.7": "9.0.9",
      "minimatch@<3.1.4": "3.1.5",
      "ajv@<6.14.0": "6.14.0",
      "hono@<4.12.4": ">=4.12.4",
      "hono@<4.12.7": ">=4.12.7",
      "flatted@<3.4.0": ">=3.4.0",
      "undici@>=7.0.0 <7.24.0": ">=7.24.0",
      "undici@>=7.17.0 <7.24.0": ">=7.24.0"
    }
  }
}
